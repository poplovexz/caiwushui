# 爬虫配置
CRAWLER_INTERVAL=3600        # 爬虫运行间隔（秒）
CRAWLER_CONCURRENT=5         # 并发爬取数量
CRAWLER_TIMEOUT=30000        # 请求超时时间（毫秒）
CRAWLER_RETRY_TIMES=3        # 重试次数
CRAWLER_RETRY_DELAY=5000     # 重试延迟（毫秒）

# 代理配置
PROXY_ENABLED=false          # 是否启用代理
PROXY_HOST=127.0.0.1        # 代理主机
PROXY_PORT=7890             # 代理端口
PROXY_USERNAME=             # 代理用户名
PROXY_PASSWORD=             # 代理密码

# 数据库配置
DB_HOST=localhost           # 数据库主机
DB_PORT=5432               # 数据库端口
DB_NAME=financeai_db       # 数据库名
DB_USER=financeai          # 数据库用户
DB_PASSWORD=financeai123   # 数据库密码

# 日志配置
LOG_LEVEL=info             # 日志级别
LOG_FILE=crawler.log       # 日志文件

# API配置
API_KEY=                   # API密钥（如果需要）
API_SECRET=                # API密钥（如果需要）
